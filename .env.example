# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-ec2-public-ip,your-domain.com
DJANGO_LOG_LEVEL=INFO

# Cookies / security
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=false

# CORS/CSRF (comma-separated)
# Keep empty when frontend and backend are served on same host through Nginx.
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=http://your-domain.com,https://your-domain.com

# PostgreSQL
POSTGRES_DB=mini_game
POSTGRES_USER=mini_game
POSTGRES_PASSWORD=replace-with-strong-db-password
