@startuml
actor "Host Client" as Host
participant "Realtime Gateway" as RT
participant "PresenceService" as Presence
participant "RoomService" as RoomSvc
participant "AuthorizationService" as AuthZ
participant "DomainEventService" as Events
participant "Scheduler / Timeout Worker" as Scheduler
database "DB" as DB
collections "Realtime Bus" as Bus

== Host disconnects ==

Host -x RT : connection lost
RT -> Presence : markDisconnected(connectionId)
Presence -> DB : resolve host participant
Presence -> DB : update participant.connection_status=disconnected_recoverable
Presence -> Events : append(participant_disconnected)
Events -> DB : insert domain_event_log
Events -> Bus : publish participant_disconnected

Presence -> Scheduler : start host grace timer(roomId, participantId)

== Grace period expires ==

Scheduler -> RoomSvc : evaluateHostRecovery(roomId, disconnectedHostParticipantId)
RoomSvc -> DB : load room + current host + participants

alt host reconnected in time
  RoomSvc --> Scheduler : no transfer needed
else host still absent
  RoomSvc -> AuthZ : computeEligibleSuccessor(participants)
  AuthZ --> RoomSvc : successor participant

  RoomSvc -> DB : update old host is_host=false
  RoomSvc -> DB : update successor is_host=true
  RoomSvc -> DB : update room.host_participant_id=successor
  RoomSvc -> DB : insert/update role assignments

  RoomSvc -> Events : append(host_transferred)
  Events -> DB : insert domain_event_log
  Events -> Bus : publish host_transferred
end
@enduml
